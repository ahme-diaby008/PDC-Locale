# ------------------------------------------------------------
# INSTALLATION D’UN COMPLÉMENT OFFICE VIA MANIFEST WEF (depuis GitHub)
# ------------------------------------------------------------

Write-Host "Téléchargement et installation du complément Office..." -ForegroundColor Cyan

# 1. URL RAW GitHub où se trouve ton manifest.xml
$ManifestUrl = "https://raw.githubusercontent.com/<user>/<repo>/<branch>/manifest.xml"

# 2. Dossier temporaire
$TempManifest = "$env:TEMP\manifest.xml"

# 3. Télécharger le manifest
Write-Host "Téléchargement du manifest depuis GitHub..." -ForegroundColor Yellow
Invoke-WebRequest -Uri $ManifestUrl -OutFile $TempManifest

# 4. Dossier WEF
$WefFolder = "$env:LOCALAPPDATA\Microsoft\Office\Wef"
if (-Not (Test-Path $WefFolder)) {
    Write-Host "Création du dossier WEF..." -ForegroundColor Yellow
    New-Item -ItemType Directory -Path $WefFolder | Out-Null
}

# 5. Copier dans WEF
Copy-Item -Path $TempManifest -Destination $WefFolder -Force
Write-Host "Manifest installé dans : $WefFolder" -ForegroundColor Green

# 6. Redémarrer Office
Get-Process excel,winword,powerpnt -ErrorAction SilentlyContinue | Stop-Process -Force

Write-Host "✅ Installation terminée ! Relancez Excel." -ForegroundColor Green
